RewriteEngine On

# Increase upload limit for Apache
# (PHP limits are set separately in php.ini or .user.ini)

# Route API requests to PHP backend
RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback: send everything else to index.html
RewriteRule ^ index.html [L]
